{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "*"
      ]
    }
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "contexts/**/*.ts",
    "contexts/**/*.tsx",
    "data/**/*.ts",
    "lib/**/*.ts",
    "services/**/*.ts",
    "screens/**/*.ts",
    "screens/**/*.tsx",
    "types/**/*.ts",
    "utils/**/*.ts",
    "validation/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "work"
  ]
}
